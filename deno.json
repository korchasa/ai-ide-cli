{
  "name": "@korchasa/ai-ide-cli",
  "version": "0.5.6",
  "license": "MIT",
  "exports": {
    ".": "./mod.ts",
    "./types": "./types.ts",
    "./process-registry": "./process-registry.ts",
    "./runtime": "./runtime/index.ts",
    "./runtime/types": "./runtime/types.ts",
    "./runtime/setting-sources": "./runtime/setting-sources.ts",
    "./runtime/capabilities": "./runtime/capabilities.ts",
    "./runtime/content": "./runtime/content.ts",
    "./runtime/tool-filter": "./runtime/tool-filter.ts",
    "./runtime/reasoning-effort": "./runtime/reasoning-effort.ts",
    "./claude/process": "./claude/process.ts",
    "./claude/stream": "./claude/stream.ts",
    "./claude/session": "./claude/session.ts",
    "./cursor/process": "./cursor/process.ts",
    "./cursor/session": "./cursor/session.ts",
    "./codex/process": "./codex/process.ts",
    "./codex/hitl-mcp": "./codex/hitl-mcp.ts",
    "./codex/app-server": "./codex/app-server.ts",
    "./codex/session": "./codex/session.ts",
    "./opencode/process": "./opencode/process.ts",
    "./opencode/session": "./opencode/session.ts",
    "./opencode/hitl-mcp": "./opencode/hitl-mcp.ts",
    "./hitl-mcp": "./hitl-mcp.ts",
    "./skill": "./skill/mod.ts"
  },
  "tasks": {
    "check": "deno run -A scripts/check.ts",
    "test": "deno test -A --no-check .",
    "fmt": "deno fmt",
    "release": "deno run -A npm:standard-version --skip.tag"
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "@std/path": "jsr:@std/path@^1.1.4",
    "@std/yaml": "jsr:@std/yaml@^1.0.12",
    "@std/fs": "jsr:@std/fs@^1.0.0"
  },
  "fmt": {
    "proseWrap": "preserve",
    "exclude": [
      "**/*.md"
    ]
  },
  "lint": {
    "exclude": [
      "scripts/"
    ]
  },
  "publish": {
    "include": [
      "./",
      "./deno.json",
      "./README.md"
    ],
    "exclude": [
      "**/*_test.ts",
      "scripts/**",
      "documents/**",
      ".github/**",
      "**/CLAUDE.md",
      "AGENTS.md",
      "CHANGELOG.md",
      "LICENSE",
      ".gitignore"
    ]
  }
}
